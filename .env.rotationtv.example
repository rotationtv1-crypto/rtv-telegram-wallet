# ============================================================
# RotationTV Network — Secrets Template
# Copy to .env and fill from your vault/password manager
# NEVER commit this file with real values
# NEVER paste tokens in chat — use CLI: wrangler secret put <KEY>
# ============================================================

# ── Telegram Bot Tokens ──
# Get from @BotFather → /token (after /revoke of old tokens)
TELEGRAM_BOT_TOKEN_ROTATIONTV=your_rotationtv_bot_token_here
TELEGRAM_BOT_TOKEN_ROTATIONWINDOWS=your_rotationwindows_bot_token_here
TELEGRAM_BOT_TOKEN_ROTATIONTVNETWORK=your_rotationtvnetwork_bot_token_here

# ── Supabase ──
# Dashboard → Settings → API
SUPABASE_URL=https://xynkgaxfwvpcixissxdz.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ── Cloudflare ──
# Dashboard → My Profile → API Tokens → Create Token
CF_API_TOKEN=your_cloudflare_api_token_here
CF_ACCOUNT_ID=your_cloudflare_account_id_here
CF_STREAM_TOKEN=your_cloudflare_stream_token_here
CF_STREAM_SIGNING_KEY=your_stream_signing_key_here

# ── Venice AI ──
# https://venice.ai → Settings → API Keys
VENICE_API_KEY=your_venice_api_key_here

# ── ElevenLabs (direct, if not using Venice TTS) ──
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── HeyGen (AI video avatars) ──
HEYGEN_API_KEY=your_heygen_api_key_here

# ── TON Blockchain ──
TON_RPC_URL=https://toncenter.com/api/v2
TON_API_KEY=your_toncenter_api_key_here
TON_WALLET_SEED=your_ton_wallet_mnemonic_here
TON_WALLET_ADDRESS=your_ton_wallet_address_here

# ── Stripe (payments) ──
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ── Twilio (SMS notifications) ──
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# ── Vercel (frontend deploys) ──
VERCEL_TOKEN=your_vercel_token_here
VERCEL_ORG_ID=your_vercel_org_id_here
VERCEL_PROJECT_ID=your_vercel_project_id_here

# ── Cron Secret (protects Edge Function endpoints) ──
CRON_SECRET=rtv-cron-secret-change-this

# ── Webhook Secrets ──
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
