{
  "type": "object",
  "properties": {
    "voip_number_id": {
      "type": "string",
      "description": "ID of the VoIPNumber this rule applies to"
    },
    "phone_number": {
      "type": "string",
      "description": "Source number for display"
    },
    "rule_name": {
      "type": "string"
    },
    "condition": {
      "type": "string",
      "enum": [
        "always",
        "busy",
        "no_answer",
        "unavailable",
        "time_based",
        "caller_id"
      ],
      "description": "When to forward"
    },
    "destination": {
      "type": "string",
      "description": "Forward-to phone number or SIP URI"
    },
    "ring_timeout_sec": {
      "type": "number",
      "description": "Seconds before forwarding"
    },
    "whisper_message": {
      "type": "string",
      "description": "Message played to recipient before connecting"
    },
    "enabled": {
      "type": "boolean"
    },
    "priority": {
      "type": "number"
    },
    "schedule_start": {
      "type": "string",
      "description": "HH:MM for time-based rules"
    },
    "schedule_end": {
      "type": "string"
    },
    "days_of_week": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rtv_module": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    }
  },
  "required": [
    "voip_number_id",
    "condition",
    "destination",
    "enabled"
  ],
  "name": "CallForwarding"
}