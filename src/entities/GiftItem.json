{
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Gift display name"
    },
    "emoji": {
      "type": "string",
      "description": "Gift emoji/icon"
    },
    "price_rtv": {
      "type": "number",
      "description": "Price in RTV tokens"
    },
    "price_usd": {
      "type": "number",
      "description": "Equivalent USD price"
    },
    "category": {
      "type": "string",
      "enum": [
        "basic",
        "premium",
        "legendary",
        "seasonal",
        "exclusive",
        "limited"
      ],
      "default": "basic"
    },
    "animation_url": {
      "type": "string",
      "description": "Lottie/SVG animation URL for on-stream gift animation"
    },
    "animation_duration_sec": {
      "type": "number",
      "default": 3
    },
    "is_limited_edition": {
      "type": "boolean",
      "default": false
    },
    "available_from": {
      "type": "string",
      "description": "ISO date when gift becomes available"
    },
    "available_until": {
      "type": "string",
      "description": "ISO date when limited gift expires"
    },
    "creator_share_pct": {
      "type": "number",
      "default": 80,
      "description": "% of gift value that goes to the receiving creator"
    },
    "platform_share_pct": {
      "type": "number",
      "default": 15
    },
    "agency_share_pct": {
      "type": "number",
      "default": 5,
      "description": "If creator has agency"
    },
    "combo_multiplier": {
      "type": "number",
      "default": 1,
      "description": "Combo bonus multiplier for streak gifting (Bigo-style)"
    },
    "max_combo": {
      "type": "number",
      "default": 100
    },
    "description": {
      "type": "string"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "created_at": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "emoji",
    "price_rtv",
    "category",
    "is_active"
  ],
  "name": "GiftItem"
}