{
  "name": "rtv-stream",
  "main": "src/index.js",
  "compatibility_date": "2024-09-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "RTV_VERSION": "3.0.0",
    "RTV_PARITY": "1 RTV = 0.01 USD"
  },
  "workers_dev": true,
  "triggers": {
    "crons": ["*/15 * * * *"]
  }
}
